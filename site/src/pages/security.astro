---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';
---
<Layout
  title="Security — Warmbly"
  description="Envelope encryption with AWS KMS, per-user data keys, audit logs, and a worker plane that never touches your relational database."
>
  <PageHero
    eyebrow="Security"
    title="Encrypted at rest. Boundary-respecting by design."
    description="Mailbox credentials, refresh tokens, and message payloads are envelope-encrypted with per-user data keys. Workers never open a Postgres connection."
  />

  <Section>
    <SectionHead
      eyebrow="Encryption"
      title="Envelope encryption with AWS KMS."
      description="A root key in AWS KMS protects per-user data encryption keys (DEKs). Plaintext DEKs never get stored — only their encrypted blobs."
    />
    <div class="mt-10 grid lg:grid-cols-3 gap-4">
      {[
        { icon: 'lock',     title: 'Root of trust',  body: 'AWS KMS holds the customer master key. We never see or export its raw key material.' },
        { icon: 'key',      title: 'Per-user DEKs',  body: 'Each organisation user gets a 32-byte AES-256 data key generated through KMS.' },
        { icon: 'database', title: 'DynamoDB storage', body: 'The encrypted DEK blob is base64-encoded and persisted in DynamoDB, not Postgres.' },
        { icon: 'cpu',      title: 'Brief cache window', body: 'Decrypted DEKs are cached in Redis with a short TTL for hot paths, never persisted to disk.' },
        { icon: 'shield',   title: 'AES-GCM sealing', body: 'Encrypted fields are sealed with AES-GCM and base64-encoded before storage.' },
        { icon: 'workflow', title: 'Worker integration', body: 'Workers receive encrypted material plus KMS-backed decryption primitives — never direct SQL.' },
      ].map((s) => (
        <Card>
          <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
            <Icon name={s.icon} size={18} />
          </div>
          <h3 class="text-[15px] font-semibold">{s.title}</h3>
          <p class="mt-1.5 text-[13.5px] text-muted-foreground leading-relaxed">{s.body}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section variant="muted">
    <SectionHead
      eyebrow="Boundaries"
      title="The control plane and the execution plane are separate."
      description="Backend and consumer own the relational state. Workers execute side effects. The two never share a database connection."
    />
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      {[
        ['No Postgres on workers', 'Workers boot Kafka, Redis cache, KMS, DynamoDB and S3 clients — not a SQL pool.'],
        ['Per-worker IPs', 'Each worker has its own machine-level network identity, no shared NAT.'],
        ['Per-worker Kafka topics', 'Commands and results are routed through worker-specific topics for traceability.'],
        ['Migrable accounts', 'The control plane can rebalance or migrate accounts between workers transparently.'],
        ['Disposable worker state', 'Workers store nothing locally that can’t be rebuilt from a Kafka replay.'],
        ['Auditable admin actions', 'Bans, rate-limit overrides, and manual interventions land in an audit log.'],
      ].map(([k, v]) => (
        <Card>
          <h3 class="text-[14.5px] font-semibold">{k}</h3>
          <p class="mt-1.5 text-[13.5px] text-muted-foreground leading-relaxed">{v}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section>
    <SectionHead
      eyebrow="Anti-abuse"
      title="Layered controls, not one brittle gate."
    />
    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        ['CAPTCHA at auth', 'Cloudflare Turnstile on login, registration, password reset and confirmation flows.'],
        ['API rate limiting', 'Per-user category-aware rate limiting backed by Redis and plan limits.'],
        ['Realtime throttling', 'WebSocket joins, messages and events all rate-limited as an anti-abuse boundary.'],
        ['Event dedupe', 'Tracking events deduped at the edge and again in the consumer; deliverability events use idempotency keys.'],
        ['Suppression', 'Bounce, complaint and unsubscribe signals suppress recipients across all campaigns automatically.'],
        ['Mailbox-sync limits', '100 new emails / 5 min burst, 500 / hour ceiling. Exceeded mailboxes are rate-limited and warned.'],
        ['Admin enforcement', 'Manual ban / unban / rate-limit override available with full history.'],
        ['Webhook signatures', 'Webhook calls are HMAC-signed; we provide rotation primitives in the dashboard.'],
      ].map(([k, v]) => (
        <Card>
          <h3 class="text-[14.5px] font-semibold">{k}</h3>
          <p class="mt-1 text-[13px] text-muted-foreground leading-relaxed">{v}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section variant="muted">
    <SectionHead
      eyebrow="Compliance"
      title="What we’re working toward — and what we already do."
    />
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      <Card>
        <h3 class="text-[15px] font-semibold">Today</h3>
        <ul class="mt-3 space-y-2">
          {[
            'GDPR-aligned data handling and DPA on request',
            'Subprocessor list published and versioned',
            'Per-organisation audit log of admin actions',
            'Configurable data residency (US / EU) on Business plan',
            'TLS 1.2+ for all in-transit traffic',
            'Per-user data encryption keys backed by AWS KMS',
          ].map((l) => (
            <li class="flex items-start gap-2 text-[13.5px] text-foreground/85">
              <Icon name="check" size={13} class="text-success mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </Card>
      <Card>
        <h3 class="text-[15px] font-semibold">In progress</h3>
        <ul class="mt-3 space-y-2">
          {[
            'SOC 2 Type II — audit in progress',
            'ISO 27001 — gap assessment complete',
            'HIPAA — covered-entity BAA pilot',
            'Customer-managed KMS keys (BYOK)',
            'Tenant-scoped IP allowlists for the API',
            'Hardware-key SSO enforcement',
          ].map((l) => (
            <li class="flex items-start gap-2 text-[13.5px] text-foreground/85">
              <Icon name="clock" size={13} class="text-warn mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </Section>

  <CTA
    title="Need our security package?"
    description="Pen test summaries, subprocessor list, DPA, SOC 2 progress letter and architecture overview — available on request."
    primaryLabel="Request security pack"
    primaryHref="/contact/?topic=security"
    secondaryLabel="Read our trust page"
    secondaryHref="/trust/"
  />
</Layout>
