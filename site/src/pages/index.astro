---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const logos = ['Loop', 'Northwind', 'Spruce', 'Heliogen', 'Foundry', 'Quanto', 'Cinder', 'Vellum', 'Atlas', 'Mosaic', 'Trellis', 'Helia'];

const ramp = [10, 11, 12, 14, 16, 18, 21, 24, 27, 30, 33, 36, 38, 40, 40];
const placement = [88, 90, 92, 93, 91, 94, 95, 96, 96, 97, 98, 98, 99];

const stats = [
  { value: '99.97%',  label: 'Worker uptime · 90 days' },
  { value: '0.04%',   label: 'Median complaint rate' },
  { value: '12.4k',   label: 'Mailboxes warming now' },
  { value: '4.2 ms',  label: 'Edge dedupe latency' },
];

const compareCold = [
  ['Per-mailbox cold cap',     'Warmbly defaults to 50/day',       'Most tools: 200/day if you ask'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on catastrophe (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your inboxes, send at scale, and keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — sky wash fading into white
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <!-- Atmospheric layers, all absolute, all CSS, no JS -->
    <div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 h-[1100px] md:h-[1280px]">
      <div class="sky-wash"></div>
      <div class="sky-grain"></div>
      <div class="sky-fade"></div>
    </div>

    <div class="container-page relative pt-20 md:pt-28 pb-14 md:pb-20">
      <!-- Eyebrow chip -->
      <div class="flex justify-center">
        <a href="/changelog/" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/70 border border-border/80 backdrop-blur text-[12px] text-foreground/80 shadow-sm">
          <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-wider bg-foreground text-background">New</span>
          <span>Per-mailbox health bands &amp; auto-quarantine recovery</span>
          <Icon name="arrowRight" size={12} class="text-muted-foreground group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>

      <!-- Headline -->
      <h1 class="mt-8 md:mt-10 text-center text-[44px] sm:text-6xl md:text-[80px] font-extrabold tracking-[-0.035em] leading-[0.98] text-foreground">
        <span class="block">Cold email that</span>
        <span class="block">
          actually lands
          <span class="inline-block align-baseline bg-gradient-to-br from-[oklch(0.55_0.18_252)] via-[oklch(0.62_0.16_232)] to-[oklch(0.65_0.14_205)] bg-clip-text text-transparent">— in the inbox.</span>
        </span>
      </h1>

      <p class="mt-6 md:mt-7 text-center text-[16.5px] md:text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-md text-[14.5px] font-medium bg-foreground text-background hover:bg-foreground/85 ring-1 ring-foreground/10 shadow-[0_10px_30px_-12px_rgba(15,23,42,0.45)] transition-colors">
          Start free
          <Icon name="arrowRight" size={15} />
        </a>
        <a href="/product/"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-md text-[14.5px] font-medium bg-white/70 border border-border/80 backdrop-blur hover:bg-white transition-colors">
          Tour the product
        </a>
      </div>

      <p class="mt-4 text-center text-[12.5px] text-muted-foreground">
        Free forever for one mailbox · 14-day Growth trial · no credit card
      </p>

      <!-- ============================================================
           HERO MOCK — layered product surfaces
      ============================================================ -->
      <div class="relative mt-14 md:mt-20">
        <!-- main app shell -->
        <div class="glass-card rounded-2xl border border-border/80 overflow-hidden">
          <!-- chrome bar -->
          <div class="flex items-center gap-2 px-4 h-10 border-b border-border/70 bg-surface-2/40">
            <div class="flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-foreground/15"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-foreground/15"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-foreground/15"></span>
            </div>
            <div class="mx-auto inline-flex items-center gap-2 h-6 px-3 rounded-md bg-white/80 border border-border/70 text-[11.5px] text-muted-foreground font-mono">
              <Icon name="lock" size={11} />
              app.warmbly.com / accounts
            </div>
            <div class="w-10"></div>
          </div>

          <div class="grid grid-cols-12 min-h-[460px]">
            <!-- sidebar -->
            <aside class="hidden md:flex md:col-span-3 lg:col-span-2 flex-col border-r border-border/70 p-3">
              <div class="flex items-center gap-2 h-8 px-2">
                <div class="w-5 h-5 rounded bg-foreground text-background grid place-items-center">
                  <svg viewBox="0 0 746 764" class="w-3 h-3" fill="currentColor"><path d="M222.805 644.772L186.274 108.881L704.5 451.158L484.5 451.158L245.5 196.158L444 463.5L222.805 644.772Z"/></svg>
                </div>
                <span class="text-[12.5px] font-semibold">Acme</span>
                <Icon name="arrowRight" size={10} class="text-muted-foreground ml-auto rotate-90" />
              </div>
              <div class="mt-2 text-[10.5px] uppercase tracking-wider font-semibold text-muted-foreground px-2 mb-1">Workspace</div>
              <nav class="space-y-0.5">
                {['Home','Accounts','Inbox','Campaigns','Contacts','Analytics','CRM','Settings'].map((it, i) => (
                  <div class={`h-7 px-2 rounded-md flex items-center gap-2 text-[12.5px] ${i===1 ? 'bg-surface-2 text-foreground font-medium' : 'text-muted-foreground'}`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-foreground/30"></span>
                    {it}
                    {i === 2 && <span class="ml-auto inline-flex items-center h-4 px-1.5 rounded text-[10px] font-semibold bg-foreground text-background">12</span>}
                  </div>
                ))}
              </nav>
              <div class="mt-4 text-[10.5px] uppercase tracking-wider font-semibold text-muted-foreground px-2 mb-1">Pools</div>
              <div class="space-y-0.5 text-[12.5px]">
                <div class="h-7 px-2 rounded-md flex items-center justify-between text-muted-foreground">
                  <span class="inline-flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Premium</span>
                  <span class="text-[10.5px] text-emerald-600">128</span>
                </div>
                <div class="h-7 px-2 rounded-md flex items-center justify-between text-muted-foreground">
                  <span class="inline-flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Recovery</span>
                  <span class="text-[10.5px] text-muted-foreground">2</span>
                </div>
              </div>
              <div class="mt-auto pt-3 border-t border-border/70 mt-3 flex items-center gap-2 text-[12px]">
                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-violet-400 to-indigo-500"></div>
                <div class="flex-1 min-w-0">
                  <div class="truncate font-medium">Maya O.</div>
                  <div class="text-[10.5px] text-muted-foreground truncate">Owner</div>
                </div>
              </div>
            </aside>

            <!-- main pane -->
            <div class="col-span-12 md:col-span-9 lg:col-span-10 p-5 md:p-6">
              <div class="flex items-start justify-between mb-5 gap-3">
                <div>
                  <h3 class="text-[16.5px] font-semibold tracking-tight">Mailbox accounts</h3>
                  <p class="text-[12.5px] text-muted-foreground">128 mailboxes · 4 workers · 5,420 sent today · all healthy</p>
                </div>
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-soft"></span>
                    workers online
                  </span>
                  <button class="inline-flex h-7 px-2.5 items-center gap-1 rounded-md text-[12px] font-medium bg-foreground text-background">
                    <Icon name="mail" size={12} /> Connect
                  </button>
                </div>
              </div>

              <!-- top KPI strip -->
              <div class="grid grid-cols-4 gap-3 mb-5">
                {[
                  { k: 'Sends today',    v: '5,420', d: '+12%',  tone: 'text-emerald-600' },
                  { k: 'Reply rate',     v: '4.8%',  d: '+0.4%', tone: 'text-emerald-600' },
                  { k: 'Spam placement', v: '3.1%',  d: '-0.6%', tone: 'text-emerald-600' },
                  { k: 'Complaints',     v: '0.02%', d: '0',     tone: 'text-muted-foreground' },
                ].map((it) => (
                  <div class="rounded-lg border border-border bg-card px-3 py-2.5">
                    <div class="text-[10.5px] uppercase tracking-wider text-muted-foreground font-semibold">{it.k}</div>
                    <div class="flex items-baseline gap-1.5 mt-0.5">
                      <span class="text-[18px] font-semibold">{it.v}</span>
                      <span class={`text-[11px] ${it.tone}`}>{it.d}</span>
                    </div>
                  </div>
                ))}
              </div>

              <!-- table -->
              <div class="rounded-lg border border-border overflow-hidden">
                <div class="grid grid-cols-12 text-[10.5px] font-semibold uppercase tracking-wider text-muted-foreground bg-surface-2/60 px-4 h-8 items-center">
                  <div class="col-span-4">Mailbox</div>
                  <div class="col-span-2">Worker</div>
                  <div class="col-span-2">Today</div>
                  <div class="col-span-2">Warmup</div>
                  <div class="col-span-2">Placement</div>
                </div>
                {[
                  ['founder@acme.co',     'eu-worker-3',  '37 / 50', '22 / 40', '98%'],
                  ['hello@acme.co',       'eu-worker-3',  '24 / 40', '18 / 40', '96%'],
                  ['team@northwind.dev',  'us-worker-7',  '46 / 50', '34 / 40', '94%'],
                  ['intro@northwind.dev', 'us-worker-7',  '42 / 50', '30 / 40', '93%'],
                  ['ml@helio.gen',        'eu-worker-1',  '18 / 30', '12 / 30', '97%'],
                  ['founder@spruce.bio',  'us-worker-2',  '12 / 40',  '8 / 30', '99%'],
                ].map(([m, w, t, wm, p]) => (
                  <div class="grid grid-cols-12 text-[13px] px-4 h-10 items-center border-t border-border hover:bg-surface-2/40 transition-colors">
                    <div class="col-span-4 font-medium truncate flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                      {m}
                    </div>
                    <div class="col-span-2 text-muted-foreground font-mono text-[12px]">{w}</div>
                    <div class="col-span-2 text-muted-foreground">{t}</div>
                    <div class="col-span-2 text-muted-foreground">{wm}</div>
                    <div class="col-span-2 text-emerald-700/90 font-medium">{p}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- floating mini cards -->
        <div class="hidden md:block absolute -left-3 lg:-left-10 -bottom-8 lg:-bottom-10 w-[260px] rounded-xl border border-border/80 glass-card p-3.5 rotate-[-3deg]">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[11px] uppercase tracking-wider font-semibold text-muted-foreground">Premium pool</span>
            <span class="inline-flex items-center gap-1.5 px-1.5 py-0.5 rounded text-[10.5px] font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> healthy
            </span>
          </div>
          <div class="grid grid-cols-3 gap-2 text-center">
            <div><div class="text-[15px] font-semibold">0.02%</div><div class="text-[10px] text-muted-foreground">Complaints</div></div>
            <div><div class="text-[15px] font-semibold">0.7%</div><div class="text-[10px] text-muted-foreground">Bounces</div></div>
            <div><div class="text-[15px] font-semibold">3.1%</div><div class="text-[10px] text-warn">Spam</div></div>
          </div>
        </div>

        <div class="hidden lg:block absolute -right-6 -bottom-10 w-[280px] rounded-xl border border-border/80 glass-card p-3.5 rotate-[2.5deg]">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[11px] uppercase tracking-wider font-semibold text-muted-foreground">Reply</span>
            <span class="text-[10.5px] font-medium text-emerald-700">positive</span>
          </div>
          <div class="text-[12.5px] font-semibold">Re: quick question on outbound</div>
          <p class="text-[12px] text-muted-foreground mt-1 leading-snug line-clamp-3">
            Sure — happy to chat. Thursday 10am ET works for me, send a calendar invite to this address.
          </p>
          <div class="mt-2.5 flex items-center gap-2 text-[11px] text-muted-foreground">
            <div class="w-4 h-4 rounded-full bg-gradient-to-br from-rose-400 to-amber-400"></div>
            <span>jenna@northwind.dev</span>
            <span class="ml-auto font-mono">2m</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LOGO MARQUEE
  ============================================================ -->
  <section class="relative border-y border-border bg-background">
    <div class="container-page py-7">
      <p class="text-center text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground mb-5">
        Trusted by 4,000+ founders, sales teams and agencies
      </p>
      <div class="marquee-mask overflow-hidden">
        <div class="marquee-track flex items-center gap-12 whitespace-nowrap w-max">
          {[...logos, ...logos].map((l) => (
            <span class="text-[18px] font-semibold tracking-tight text-foreground/55 hover:text-foreground transition-colors">{l}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BENTO — densely packed feature grid
  ============================================================ -->
  <section class="container-page py-20 md:py-28">
    <div class="max-w-3xl">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-4">
        One platform
      </span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.025em] leading-[1.04]">
        Warmup, sending and inbox — engineered together.
      </h2>
      <p class="mt-4 text-[16px] md:text-[17px] text-muted-foreground max-w-2xl leading-relaxed">
        Most tools bolt warmup onto an SMTP relay. We built sending, warmup, analytics and inbox as one system so the signal one part collects is the signal the next part acts on.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-6 gap-3.5">
      <!-- 1. Warmup ramp chart (wide) -->
      <div class="md:col-span-4 rounded-2xl border border-border bg-card p-6 overflow-hidden">
        <div class="flex items-start justify-between">
          <div>
            <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
              <Icon name="flame" size={18} />
            </div>
            <h3 class="text-[17px] font-semibold tracking-tight">Reputation-safe warmup</h3>
            <p class="mt-1.5 text-[14px] text-muted-foreground max-w-md leading-relaxed">
              Start at 10/day, ramp +1/day to a 40/day ceiling. Conversational replies. Quarantine on warning, not catastrophe.
            </p>
          </div>
          <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10.5px] font-semibold uppercase tracking-wider text-emerald-700 bg-emerald-50 border border-emerald-100">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-soft"></span> healthy
          </span>
        </div>
        <!-- chart -->
        <div class="mt-7 relative h-44">
          <div class="absolute inset-x-0 bottom-0 grid grid-cols-15 items-end gap-1.5 h-40">
            {ramp.map((v) => (
              <div class="rounded-t-md bg-gradient-to-t from-[oklch(0.62_0.13_252)] to-[oklch(0.78_0.10_232)]"
                   style={`height:${(v / 40) * 100}%`}></div>
            ))}
          </div>
          <div class="absolute left-0 right-0 top-0 flex justify-between text-[10px] text-muted-foreground font-mono">
            <span>day 1 · 10/day</span>
            <span>day 30 · 40/day ceiling</span>
          </div>
        </div>
      </div>

      <!-- 2. Worker distribution (narrow) -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6">
        <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
          <Icon name="cpu" size={18} />
        </div>
        <h3 class="text-[17px] font-semibold tracking-tight">Distributed sending</h3>
        <p class="mt-1.5 text-[14px] text-muted-foreground leading-relaxed">
          One worker per machine. Each with its own IP. We add workers before forcing each to do more.
        </p>
        <div class="mt-5 space-y-2">
          {[
            ['eu-worker-3',  68],
            ['us-worker-7',  54],
            ['eu-worker-1',  41],
            ['us-worker-2',  27],
          ].map(([name, pct]) => (
            <div>
              <div class="flex items-center justify-between text-[11.5px] font-mono text-muted-foreground mb-1">
                <span>{name}</span><span>{pct}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-surface-2 overflow-hidden">
                <div class="h-full rounded-full bg-foreground/80" style={`width:${pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Unified inbox preview -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6">
        <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
          <Icon name="inbox" size={18} />
        </div>
        <h3 class="text-[17px] font-semibold tracking-tight">Unified inbox</h3>
        <p class="mt-1.5 text-[14px] text-muted-foreground leading-relaxed">
          Every reply across every mailbox in one console — classified, assignable.
        </p>
        <div class="mt-5 space-y-1.5">
          {[
            { who: 'Jenna · Northwind', snippet: 'Sure — Thursday 10am ET',   tag: 'positive', tone: 'text-emerald-700' },
            { who: 'Tom · Spruce',       snippet: 'Add me to your blocklist',  tag: 'unsub',    tone: 'text-muted-foreground' },
            { who: 'Out of office',      snippet: 'I’m away until Monday',     tag: 'OOO',      tone: 'text-amber-700' },
          ].map((r) => (
            <div class="rounded-lg border border-border bg-surface-2/40 p-2.5">
              <div class="flex items-center justify-between text-[11.5px]">
                <span class="font-medium truncate">{r.who}</span>
                <span class={`text-[10px] font-semibold uppercase tracking-wider ${r.tone}`}>{r.tag}</span>
              </div>
              <p class="text-[12px] text-muted-foreground mt-0.5 truncate">{r.snippet}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 4. Placement ring (medium) -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
          <Icon name="chart" size={18} />
        </div>
        <h3 class="text-[17px] font-semibold tracking-tight">Placement, not opens</h3>
        <p class="mt-1.5 text-[14px] text-muted-foreground leading-relaxed">
          We probe inbox placement through the pool, then act on it.
        </p>
        <div class="mt-5 flex items-center justify-center flex-1">
          <div class="relative w-32 h-32">
            <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="currentColor" stroke-width="2.6" class="text-surface-3"></circle>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="url(#g1)" stroke-width="2.6" stroke-dasharray="96 100" stroke-linecap="round"></circle>
              <defs>
                <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="oklch(0.55 0.18 252)"></stop>
                  <stop offset="100%" stop-color="oklch(0.72 0.12 220)"></stop>
                </linearGradient>
              </defs>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-2xl font-extrabold tracking-tight">96%</span>
              <span class="text-[10.5px] uppercase tracking-wider text-muted-foreground">inbox</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 5. Sequences (wide) -->
      <div class="md:col-span-4 rounded-2xl border border-border bg-card p-6">
        <div class="flex items-start justify-between">
          <div>
            <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
              <Icon name="workflow" size={18} />
            </div>
            <h3 class="text-[17px] font-semibold tracking-tight">Sequences with conditions</h3>
            <p class="mt-1.5 text-[14px] text-muted-foreground max-w-md leading-relaxed">
              Up to 12 steps. A/B variants on subject and body. Business-hour delays by recipient time zone. Branch on reply, open, click or bounce.
            </p>
          </div>
        </div>
        <div class="mt-6 grid md:grid-cols-4 gap-2">
          {[
            { n: 'Step 1', t: 'Intro · plain text',         m: '2 variants',  tone: 'text-emerald-700' },
            { n: 'Step 2', t: 'Wait 3 biz days',            m: 'if no reply', tone: 'text-muted-foreground' },
            { n: 'Step 3', t: 'Follow-up · context line',   m: '4 variants',  tone: 'text-emerald-700' },
            { n: 'Step 4', t: 'Soft break · 7 biz days',    m: 'if no open',  tone: 'text-muted-foreground' },
          ].map((s) => (
            <div class="rounded-lg border border-border bg-surface-2/40 p-3">
              <div class="flex items-center justify-between text-[10.5px] font-mono text-muted-foreground">
                <span>{s.n}</span>
                <span class={s.tone}>{s.m}</span>
              </div>
              <div class="mt-1.5 text-[13px] font-medium">{s.t}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- 6. Placement trend (full row) -->
      <div class="md:col-span-6 rounded-2xl border border-border bg-card p-6 overflow-hidden">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div>
