---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';
import HeroSparks from '../components/HeroSparks.astro';

const logos = ['Loop', 'Northwind', 'Spruce', 'Heliogen', 'Foundry', 'Quanto', 'Cinder', 'Vellum', 'Atlas', 'Mosaic'];

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — centered headline, CTAs, then pastel gradient-accent
       card wrapping the product mock (Adora pattern)
  ============================================================ -->
  <section class="relative">
    <div class="container-page pt-16 md:pt-20 pb-10 md:pb-14 text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[12px] font-medium tracking-[-0.02em] text-neon-pink border border-[color:var(--neon-pink)]/40 bg-[color:var(--neon-pink)]/5">
        <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--neon-pink)]"></span>
        New · per-mailbox health bands &amp; auto-quarantine
      </span>

      <h1
        class="mt-8 text-[40px] sm:text-[58px] md:text-[68px] font-bold tracking-[-0.02em] leading-[1.05] text-heading mx-auto max-w-4xl"
        style="font-family: var(--font-display);"
      >
        Cold email that actually lands in the inbox.
      </h1>

      <p class="mt-6 text-[18px] md:text-[20px] tracking-[-0.02em] leading-relaxed text-foreground mx-auto max-w-2xl">
        Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://app.warmbly.com/register"
          class="inline-flex h-11 px-5 items-center gap-2 rounded-[12px] text-[15px] font-medium text-white bg-[color:var(--brand)] hover:bg-[color:var(--brand-strong)] transition-colors"
        >
          Start free
          <Icon name="arrowRight" size={15} />
        </a>
        <a
          href="/product/"
          class="inline-flex h-11 px-5 items-center gap-2 rounded-[12px] text-[15px] font-medium text-foreground border border-[color:var(--border)] hover:bg-surface-2 transition-colors"
        >
          Tour the product
        </a>
      </div>
      <p class="mt-4 text-[13px] text-muted-foreground tracking-[-0.02em]">
        Free forever for one mailbox · 14-day Growth trial · no credit card.
      </p>
    </div>

    <!-- ===== Pastel Gradient Accent Card wrapping the product mock ===== -->
    <div class="container-page pb-20 md:pb-28">
      <div
        class="relative overflow-hidden p-6 sm:p-10 md:p-12 lg:p-16"
        style="background: linear-gradient(135deg, var(--air-blue) 0%, #d6f4ff 45%, #ffe0f4 100%); border-radius: 48px;"
      >
        <HeroSparks />
        <!-- ambient decorative outlined cloud, top-left -->
        <svg
          aria-hidden="true"
          class="absolute pointer-events-none opacity-40"
          style="top: -32px; left: -32px; width: 240px; height: 160px;"
          viewBox="0 0 240 160" fill="none" stroke="white" stroke-width="2"
        >
          <path d="M30 100 Q30 70 60 70 Q70 40 110 45 Q140 30 165 55 Q195 50 205 80 Q220 95 200 115 L60 115 Q30 115 30 100 Z" />
        </svg>
        <div class="relative rounded-[20px] overflow-hidden ring-1 ring-black/[0.06] shadow-[0_30px_60px_-20px_rgba(33,22,76,0.18)]">
          <DashboardMock />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LOGOS
  ============================================================ -->
  <section class="border-y border-border bg-white">
    <div class="container-page py-9">
      <p class="text-center text-[12px] tracking-[-0.02em] font-medium text-muted-foreground mb-6">
        Trusted every day by teams that build cold outbound at scale
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-y-4 gap-x-6 items-center">
        {logos.slice(0, 5).map((l) => (
          <span class="text-center text-[17px] font-semibold tracking-[-0.02em] text-foreground/55">{l}</span>
        ))}
      </div>
      <div class="mt-3 grid grid-cols-2 sm:grid-cols-5 gap-y-4 gap-x-6 items-center">
        {logos.slice(5).map((l) => (
          <span class="text-center text-[17px] font-semibold tracking-[-0.02em] text-foreground/55">{l}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 1 — Warmup (text left, mock right in Lush Green card)
  ============================================================ -->
  <section class="container-page py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-5">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-semibold tracking-[-0.02em] text-[color:var(--electric-green)] border border-[color:var(--electric-green)]/40 bg-[color:var(--electric-green)]/10 mb-5">
          Warmup
        </span>
        <h2 class="text-[32px] md:text-[44px] font-bold tracking-[-0.02em] leading-[1.05] text-heading">
          A warmup pool that quarantines before mailbox providers do.
        </h2>
        <p class="mt-5 text-[16px] tracking-[-0.02em] text-foreground leading-relaxed">
          Free and premium pools never mix. Spam-score tracking, verification tokens and recent-partner avoidance keep traffic natural. Anything past the watch band gets pulled.
        </p>
        <ul class="mt-7 space-y-3 text-[15px]">
          {[
            'Start 10/day, ramp +1/day, ceiling 40/day',
            '≥ 3 invalid tokens / 24h → auto-block',
            'Spam score > 50 → recovery pool',
            'Re-entry requires fresh probation',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
        <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-[color:var(--brand)] hover:text-[color:var(--brand-strong)] group">
          See how warmup works
          <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>

      <div class="lg:col-span-7">
        <div
          class="relative p-6 md:p-10"
          style="background: linear-gradient(135deg, var(--lush-green) 0%, #efffd0 100%); border-radius: 40px;"
        >
          <div class="relative rounded-[16px] overflow-hidden ring-1 ring-black/[0.06] shadow-[0_24px_50px_-22px_rgba(33,22,76,0.18)]">
            <WarmupMock />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 2 — Inbox (Sunset Pink card, text right)
  ============================================================ -->
  <section class="bg-surface-2 border-y border-border">
    <div class="container-page py-24 md:py-32">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div
            class="relative p-6 md:p-10"
            style="background: linear-gradient(135deg, var(--sunset-pink) 0%, #ffd2ee 100%); border-radius: 40px;"
          >
            <div class="relative rounded-[16px] overflow-hidden ring-1 ring-black/[0.06] shadow-[0_24px_50px_-22px_rgba(33,22,76,0.18)]">
              <InboxMock />
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 order-1 lg:order-2">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-semibold tracking-[-0.02em] text-[color:var(--neon-pink)] border border-[color:var(--neon-pink)]/40 bg-[color:var(--neon-pink)]/10 mb-5">
            Unified inbox
          </span>
          <h2 class="text-[32px] md:text-[44px] font-bold tracking-[-0.02em] leading-[1.05] text-heading">
            One inbox for every mailbox you send from.
          </h2>
          <p class="mt-5 text-[16px] tracking-[-0.02em] text-foreground leading-relaxed">
            No more bouncing between Gmail tabs to handle replies from your eight cold mailboxes. Reply detection survives quoted text. OOO and unsubscribe auto-suppress.
          </p>
          <ul class="mt-7 space-y-3 text-[15px]">
            {[
              'Positive / negative / OOO / unsub / bounce classification',
              'Cross-mailbox search and saved views',
              'Round-robin or domain-aware assignment',
              'Realtime push for replies, not for opens',
            ].map((l) => (
              <li class="flex items-start gap-2.5">
                <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <a href="/inbox/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-[color:var(--brand)] hover:text-[color:var(--brand-strong)] group">
            Explore the inbox <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 3 — Sending engine (Air Blue card, text left)
  ============================================================ -->
  <section class="container-page py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-5">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-semibold tracking-[-0.02em] text-[color:var(--aqua-blue)] border border-[color:var(--aqua-blue)]/40 bg-[color:var(--aqua-blue)]/10 mb-5">
          Sending engine
        </span>
        <h2 class="text-[32px] md:text-[44px] font-bold tracking-[-0.02em] leading-[1.05] text-heading">
          A distributed send plane, not a glorified SMTP relay.
        </h2>
        <p class="mt-5 text-[16px] tracking-[-0.02em] text-foreground leading-relaxed">
          One worker per machine. Each with its own IP. We add workers before we make any single one carry more weight.
        </p>
        <ul class="mt-7 space-y-3 text-[15px]">
          {[
            'Default 50/day cold cap per mailbox',
            'Minimum 10-minute gap between sends',
            'Worker volume = sum of mailbox budgets',
            'Native Gmail · Outlook · SMTP/IMAP',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-7">
        <div
          class="relative p-6 md:p-10"
          style="background: linear-gradient(135deg, var(--air-blue) 0%, #e0f6ff 100%); border-radius: 40px;"
        >
          <div class="relative bg-white rounded-[16px] overflow-hidden ring-1 ring-black/[0.06] shadow-[0_24px_50px_-22px_rgba(33,22,76,0.18)]">
            <div class="h-10 px-4 border-b border-slate-200 flex items-center gap-2 bg-[#fafafa]">
              <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
              <span class="mx-auto inline-flex items-center gap-2 h-6 px-3 rounded bg-white border border-slate-200 text-[11.5px] text-slate-500 font-mono">warmbly.com / workers</span>
              <span class="w-12"></span>
            </div>
            <div class="bg-white">
              <div class="h-12 px-5 border-b border-slate-200 flex items-center gap-3">
                <span class="text-[10px] uppercase tracking-[0.14em] text-slate-400 font-medium">Workers</span>
                <div class="h-4 w-px bg-slate-200"></div>
                <span class="text-[12.5px] text-slate-600">4 workers · 128 mailboxes · 5,420 sent today</span>
              </div>
              <div class="divide-y divide-slate-200/60">
                {[
                  { name: 'eu-worker-3', region: 'eu-west-1', mb: 38, sent: 1842, ip: '52.18.214.91' },
                  { name: 'us-worker-7', region: 'us-east-1', mb: 32, sent: 1456, ip: '54.221.190.17' },
                  { name: 'eu-worker-1', region: 'eu-west-1', mb: 30, sent: 1210, ip: '52.18.220.44' },
                  { name: 'us-worker-2', region: 'us-east-1', mb: 28, sent:  912, ip: '54.221.196.21' },
                ].map((w) => (
                  <div class="px-5 py-3 grid grid-cols-12 items-center text-[12.5px] gap-3">
                    <div class="col-span-4 flex items-center gap-2">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                      <span class="font-mono text-slate-900 font-medium">{w.name}</span>
                      <span class="text-slate-400 font-mono text-[11px]">· {w.region}</span>
                    </div>
                    <div class="col-span-2 text-slate-500 font-mono text-[11.5px]">{w.ip}</div>
                    <div class="col-span-2 text-slate-500 tabular-nums">{w.mb} mailboxes</div>
                    <div class="col-span-2 text-slate-500 tabular-nums">{w.sent.toLocaleString()} today</div>
                    <div class="col-span-2">
                      <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
                        <div class="h-full rounded-full" style={`width:${(w.mb / 50) * 100}%; background:var(--brand);`}></div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMPARE STRIP
  ============================================================ -->
  <section class="bg-surface-2 border-y border-border">
    <div class="container-page py-20 md:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-semibold tracking-[-0.02em] text-[color:var(--brand)] border border-[color:var(--brand)]/30 bg-[color:var(--brand)]/5 mb-4">
          Why we’re different
        </span>
        <h2 class="text-[32px] md:text-[48px] font-bold tracking-[-0.02em] leading-[1.05] text-heading">
          We refuse to be the reason your domain ends up on a blocklist.
        </h2>
        <p class="mt-4 text-foreground leading-relaxed max-w-2xl">
          Most cold-email platforms reward you for sending more. We reward you for sending well. Defaults that keep you safe even if you never touch them.
        </p>
      </div>

      <div class="mt-10 rounded-[26px] bg-white overflow-hidden ring-1 ring-[color:var(--border)]">
        <div class="grid grid-cols-12 px-5 md:px-8 h-12 items-center text-[11px] font-semibold uppercase tracking-wider text-muted-foreground border-b border-border bg-surface-2/40">
          <div class="col-span-4">Setting</div>
          <div class="col-span-4">Warmbly</div>
          <div class="col-span-4">Other cold-email tools</div>
        </div>
        {compare.map(([k, ours, theirs]) => (
          <div class="grid grid-cols-12 px-5 md:px-8 py-4 items-start border-b border-border last:border-b-0 text-[14px]">
            <div class="col-span-4 font-semibold text-heading">{k}</div>
            <div class="col-span-4 text-foreground/90 flex items-start gap-2">
              <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
              <span>{ours}</span>
            </div>
            <div class="col-span-4 text-muted-foreground flex items-start gap-2">
              <Icon name="warning" size={14} class="text-amber-600 mt-1 shrink-0" />
              <span>{theirs}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       BENTO — feature cards
  ============================================================ -->
  <section class="container-page py-24 md:py-28">
    <div class="max-w-3xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-[12px] font-semibold tracking-[-0.02em] text-[color:var(--brand)] border border-[color:var(--brand)]/30 bg-[color:var(--brand)]/5 mb-4">
        One platform
      </span>
      <h2 class="text-[32px] md:text-[48px] font-bold tracking-[-0.02em] leading-[1.05] text-heading">
        Warmup, sending, inbox — engineered together.
      </h2>
      <p class="mt-4 text-foreground leading-relaxed max-w-2xl">
        The signal one part collects is the signal the next part acts on. Nothing exists in a vacuum.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-6 gap-4">
      <div class="md:col-span-2 rounded-[26px] bg-white ring-1 ring-[color:var(--border)] p-6 flex flex-col">
        <Icon name="shield" class="text-[color:var(--brand)]" />
        <h3 class="mt-4 text-[18px] font-semibold tracking-[-0.02em] text-heading">Quarantines on warning, not catastrophe</h3>
        <p class="mt-2 text-[14px] text-foreground leading-relaxed">
          Watch band kicks in at 10% spam placement — months before mailbox providers act.
        </p>
        <div class="mt-auto pt-5 grid grid-cols-4 gap-1.5">
          {['Healthy','Watch','Quarantined','Blocked'].map((b, i) => (
            <div class={`rounded-md px-1.5 py-1 text-center text-[10px] font-semibold tracking-wider ${
              i === 0 ? 'bg-emerald-50 text-emerald-700' :
              i === 1 ? 'bg-amber-50 text-amber-700' :
              i === 2 ? 'bg-orange-50 text-orange-700' :
                        'bg-rose-50 text-rose-700'}`}>{b}</div>
          ))}
        </div>
      </div>

      <div class="md:col-span-2 rounded-[26px] bg-white ring-1 ring-[color:var(--border)] p-6 flex flex-col">
        <Icon name="chart" class="text-[color:var(--brand)]" />
        <h3 class="mt-4 text-[18px] font-semibold tracking-[-0.02em] text-heading">Placement, not open rate</h3>
        <p class="mt-2 text-[14px] text-foreground leading-relaxed">
          We probe inbox placement through the pool, then act on it.
        </p>
        <div class="mt-auto pt-5 flex items-center justify-center">
          <div class="relative w-28 h-28">
            <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#eeeeee" stroke-width="2.6"></circle>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--brand)" stroke-width="2.6" stroke-dasharray="96 100" stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-xl font-extrabold tracking-tight text-heading">96%</span>
              <span class="text-[9.5px] uppercase tracking-wider text-muted-foreground">inbox</span>
            </div>
          </div>
        </div>
      </div>

      <div class="md:col-span-2 rounded-[26px] bg-white ring-1 ring-[color:var(--border)] p-6 flex flex-col">
        <Icon name="cpu" class="text-[color:var(--brand)]" />
        <h3 class="mt-4 text-[18px] font-semibold tracking-[-0.02em] text-heading">Distributed across workers &amp; IPs</h3>
        <p class="mt-2 text-[14px] text-foreground leading-relaxed">
          One worker per machine. Each with its own IP. Migrable on the fly.
        </p>
        <div class="mt-auto pt-5 space-y-2">
          {[
            { name: 'eu-worker-3', pct: 78 },
            { name: 'us-worker-7', pct: 56 },
            { name: 'eu-worker-1', pct: 41 },
          ].map((w) => (
            <div>
              <div class="flex items-center justify-between text-[11.5px] font-mono text-muted-foreground mb-1">
                <span>{w.name}</span><span>{w.pct}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-surface-2 overflow-hidden">
                <div class="h-full rounded-full" style={`width:${w.pct}%; background:var(--brand);`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="md:col-span-3 rounded-[26px] bg-white ring-1 ring-[color:var(--border)] p-6">
        <Icon name="workflow" class="text-[color:var(--brand)]" />
        <h3 class="mt-4 text-[18px] font-semibold tracking-[-0.02em] text-heading">Sequences with branching, A/B and TZ-aware delays</h3>
        <p class="mt-2 text-[14px] text-foreground leading-relaxed">
          Up to 12 steps. Variants per step. Business-hour delays by recipient time zone.
        </p>
        <div class="mt-5 grid grid-cols-4 gap-2">
          {[
            { n: 'Step 1', t: 'Intro · plain text',  m: '2 variants' },
            { n: 'Step 2', t: 'Wait 3 biz days',     m: 'if no reply' },
            { n: 'Step 3', t: 'Follow-up · context', m: '4 variants' },
            { n: 'Step 4', t: 'Soft break · 7 days', m: 'if no open' },
          ].map((s) => (
            <div class="rounded-lg ring-1 ring-[color:var(--border)] p-2.5">
              <div class="flex items-center justify-between text-[9.5px] font-mono text-muted-foreground uppercase tracking-wider">
                <span>{s.n}</span><span class="text-foreground/60">{s.m}</span>
              </div>
              <div class="mt-1.5 text-[12px] font-medium text-heading leading-snug">{s.t}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="md:col-span-3 rounded-[26px] bg-white ring-1 ring-[color:var(--border)] p-6">
        <Icon name="users" class="text-[color:var(--brand)]" />
        <h3 class="mt-4 text-[18px] font-semibold tracking-[-0.02em] text-heading">Vetted pool, real reputation surface</h3>
        <p class="mt-2 text-[14px] text-foreground leading-relaxed">
          Premium pool diversity across Gmail, Outlook, iCloud, Yahoo and self-hosted IMAP.
        </p>
        <div class="mt-5 grid grid-cols-5 gap-2">
          {[
            { name: 'Gmail',     pct: 46, color: 'bg-rose-500' },
            { name: 'Outlook',   pct: 24, color: 'bg-sky-500' },
            { name: 'Yahoo',     pct: 12, color: 'bg-violet-500' },
            { name: 'iCloud',    pct:  9, color: 'bg-zinc-500' },
            { name: 'Self-IMAP', pct:  9, color: 'bg-emerald-500' },
          ].map((p) => (
            <div class="rounded-lg ring-1 ring-[color:var(--border)] p-2.5">
              <div class={`w-1.5 h-1.5 rounded-full ${p.color}`}></div>
              <div class="mt-1 text-[11px] font-medium text-heading">{p.name}</div>
              <div class="text-[11px] text-muted-foreground font-mono">{p.pct}%</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       QUOTE BAND
  ============================================================ -->
  <section class="bg-surface-2 border-y border-border">
    <div class="container-page py-20 md:py-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
