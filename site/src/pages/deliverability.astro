---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

const bands = [
  { provider: 'Google',           threshold: '< 0.10% spam rate',  detail: 'Avoid ever reaching 0.30%. We alert above 0.03%.' },
  { provider: 'Amazon SES',       threshold: '< 0.10% complaints', detail: 'At 0.10% SES auto-reviews; at 0.50% it can pause sending.' },
  { provider: 'Amazon SES bounces', threshold: '< 5% bounces',     detail: 'At 5% the account is reviewed; at 10% sending may pause.' },
  { provider: 'Microsoft 365',    threshold: 'Use a bulk provider', detail: 'Exchange Online docs explicitly say to use specialists for bulk mail.' },
];
---
<Layout
  title="Deliverability — Warmbly"
  description="A platform built around inbox placement: per-mailbox health, real-time complaint and bounce signals, automatic quarantine before providers act."
>
  <PageHero
    eyebrow="Deliverability"
    title="A platform built so the inbox is the default outcome."
    description="Inbox placement isn’t a setting you toggle on. It’s the cumulative result of authentication, warmup, volume discipline, content quality and provider-side reputation. We instrument every one of those."
  />

  <!-- Authentication -->
  <Section>
    <SectionHead
      eyebrow="Authentication"
      title="SPF, DKIM and DMARC — checked, not assumed."
      description="The platform inspects DNS for every connected mailbox and surfaces alignment issues before you send the first campaign."
    />
    <div class="mt-10 grid md:grid-cols-3 gap-4">
      {[
        { name: 'SPF',   icon: 'cloud', body: 'We verify the sender domain’s SPF record authorises both the mailbox provider and any third-party services you use to send.' },
        { name: 'DKIM',  icon: 'key',   body: 'We check that DKIM is published, the selector resolves, and the key length is at least 1024 bits.' },
        { name: 'DMARC', icon: 'shield',body: 'We surface DMARC policy (none/quarantine/reject), alignment mode, and the rua reporting address — and warn on `p=none`.' },
      ].map((a) => (
        <Card>
          <div class="w-9 h-9 rounded-lg bg-brand-soft text-brand inline-flex items-center justify-center mb-4">
            <Icon name={a.icon} size={18} />
          </div>
          <h3 class="text-[15.5px] font-semibold">{a.name}</h3>
          <p class="mt-1.5 text-[13.5px] text-muted-foreground leading-relaxed">{a.body}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Provider thresholds -->
  <Section variant="muted">
    <SectionHead
      eyebrow="What we measure against"
      title="Provider thresholds you can verify."
      description="We chose the platform-wide bands so you trip them weeks before mailbox providers do. Here are the public thresholds we benchmark against."
    />
    <div class="mt-10 overflow-hidden rounded-xl border border-border bg-card">
      <table class="w-full text-[14px]">
        <thead class="bg-surface-2/70 text-[12px] uppercase tracking-wider text-muted-foreground">
          <tr>
            <th class="text-left font-semibold px-5 py-3">Provider</th>
            <th class="text-left font-semibold px-5 py-3">Threshold</th>
            <th class="text-left font-semibold px-5 py-3">What we do</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {bands.map((b) => (
            <tr>
              <td class="px-5 py-3 font-medium">{b.provider}</td>
              <td class="px-5 py-3"><span class="kbd">{b.threshold}</span></td>
              <td class="px-5 py-3 text-muted-foreground">{b.detail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <!-- Signals we track -->
  <Section>
    <SectionHead
      eyebrow="Signals"
      title="What we watch, in real time."
    />
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        { title: 'Inbox vs spam placement', body: 'Per-mailbox placement tracked through warmup probes and recipient feedback.' },
        { title: 'Complaint rate',          body: 'ARF complaints, Gmail FBLs, and explicit “mark as spam” signals from connected mailboxes.' },
        { title: 'Bounce rate',             body: 'Hard and soft bounces by mailbox and domain, with reason classification.' },
        { title: 'Warmup token health',     body: 'Missing, malformed, or replayed verification tokens count as suspicion.' },
        { title: 'Reply detection',         body: 'Recipients replying is the strongest positive deliverability signal we have.' },
        { title: 'OOO and auto-replies',    body: 'Classified so they don’t pollute reply rate or trigger sequence steps.' },
        { title: 'Provider throttling',     body: '4xx and rate-limit responses tracked per mailbox and exposed as health signals.' },
        { title: 'Connection abuse',        body: 'Burst syncs (>100 in 5 min) and hourly syncs (>500) rate-limit the mailbox automatically.' },
      ].map((s) => (
        <Card>
          <h3 class="text-[14.5px] font-semibold">{s.title}</h3>
          <p class="mt-1.5 text-[13px] text-muted-foreground leading-relaxed">{s.body}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- Sending posture -->
  <Section variant="muted">
    <SectionHead
      eyebrow="Sending posture"
      title="Conservative by default. Tunable on purpose."
    />
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      {[
        ['Fresh mailbox', 'Start cold outreach around 10–20/day. Ramp slowly while reputation holds.'],
        ['Stable mailbox', 'Normal safe band is 30–50/day. Default cap is 50/day.'],
        ['Above 50/day', 'Requires positive reputation signals, low complaint rates, and explicit review.'],
        ['Never burst', 'Maintain spacing between sends. Avoid bursty patterns from the same mailbox.'],
        ['Worker concentration', 'A shared worker shouldn’t carry more than ~10 actively-sending cold mailboxes at default settings.'],
        ['Dedicated workers', 'Scale volume by adding healthy mailboxes, not by forcing a few inboxes to send more.'],
      ].map(([k, v]) => (
        <Card>
          <h3 class="text-[15px] font-semibold">{k}</h3>
          <p class="mt-1.5 text-[13.5px] text-muted-foreground leading-relaxed">{v}</p>
        </Card>
      ))}
    </div>
  </Section>

  <CTA
    title="Audit your sending health today."
    description="Connect a mailbox and get a full SPF / DKIM / DMARC / placement report in under five minutes."
    primaryLabel="Run a free audit"
  />
</Layout>
