---
interface Props {
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  title = 'Start sending cold email that lands.',
  description = 'Connect a mailbox in a minute, warm it up automatically, then send your first sequence today.',
  primaryLabel = 'Start free',
  primaryHref = 'https://app.warmbly.com/register',
  secondaryLabel = 'See pricing',
  secondaryHref = '/pricing/',
} = Astro.props;
---
<section class="border-t border-border bg-foreground text-background">
  <div class="container-page py-16 md:py-20 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <div>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight leading-tight max-w-2xl">{title}</h2>
      <p class="mt-2 text-background/70 max-w-2xl">{description}</p>
    </div>
    <div class="flex flex-wrap gap-3 shrink-0">
      <a href={primaryHref} class="inline-flex h-11 px-5 items-center rounded-md text-[14.5px] font-medium bg-background text-foreground hover:bg-background/90 transition-colors">{primaryLabel}</a>
      <a href={secondaryHref} class="inline-flex h-11 px-5 items-center rounded-md text-[14.5px] font-medium border border-background/20 hover:bg-background/10 transition-colors">{secondaryLabel}</a>
    </div>
  </div>
</section>
