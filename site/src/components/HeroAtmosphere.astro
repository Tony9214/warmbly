---
import Cloud from './Cloud.astro';
/**
 * Deep-sky hero atmosphere with realistic painterly clouds.
 * No feDisplacementMap (Safari-safe). Clouds are hand-drawn bezier
 * shapes with linear-gradient shading.
 */
---
<div class="sky-base" aria-hidden="true"></div>
<div class="sky-breathe" aria-hidden="true"></div>
<div class="sky-haze-bottom" aria-hidden="true"></div>
<div class="sun-glow" aria-hidden="true"></div>

<!-- Cloud bank — five painterly clouds drifting at different speeds -->
<div class="cloud-drift cloud-1 absolute pointer-events-none" style="top: 6%; left: 4%; width: 360px;">
  <Cloud variant={2} opacity={0.95} />
</div>
<div class="cloud-drift cloud-2 absolute pointer-events-none" style="top: 4%; right: 6%; width: 420px;">
  <Cloud variant={5} opacity={0.92} />
</div>
<div class="cloud-drift cloud-3 absolute pointer-events-none" style="top: 38%; left: 18%; width: 300px;">
  <Cloud variant={3} opacity={0.78} />
</div>
<div class="cloud-drift cloud-1 absolute pointer-events-none" style="top: 32%; right: 22%; width: 240px;">
  <Cloud variant={4} opacity={0.70} />
</div>
<div class="cloud-drift cloud-2 absolute pointer-events-none" style="top: 58%; left: 40%; width: 220px;">
  <Cloud variant={1} opacity={0.62} />
</div>

<!-- Twinkling spark -->
<svg
  aria-hidden="true"
  class="absolute pointer-events-none animate-pulse-soft"
  style="top: 16%; left: 30%; width: 14px; height: 14px;"
  viewBox="0 0 14 14" fill="none"
>
  <path d="M7 1 L8.5 5.5 L13 7 L8.5 8.5 L7 13 L5.5 8.5 L1 7 L5.5 5.5 Z" fill="rgba(255,255,255,0.9)" />
</svg>
